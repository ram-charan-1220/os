#include <stdio.h>
int main()
{
    int p[20], f[10], n, m, i, j, k = 0, fault = 0, found;

    scanf("%d%d", &n, &m);

    for(i = 0; i < n; i++)
        scanf("%d", &p[i]);

    for(i = 0; i < m; i++)
        f[i] = -1;

    for(i = 0; i < n; i++)
    {
        found = 0;

        for(j = 0; j < m; j++)
            if(f[j] == p[i])
                found = 1;

        if(!found)
        {
            f[k] = p[i];
            k = (k + 1) % m;
            fault++;
        }
    }

    printf("Page Faults = %d", fault);
}
